{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/python-quality-after-edit.py",
            "timeout": 180,
            "statusMessage": "Running Ruff and ty after Python edit"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/python-quality-before-stop.py",
            "timeout": 300,
            "statusMessage": "Running final Python quality check"
          }
        ]
      }
    ]
  }
}
